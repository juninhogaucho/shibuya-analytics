# Environment Variables Example
# Copy this to .env and fill in your values

# API Base URL
# For local development:
# VITE_API_BASE=http://localhost:8001
# For production:
# VITE_API_BASE=https://api.shibuya-analytics.com

# Private demo gate
# Set this only for controlled founder demos. The value is checked client-side,
# so do not treat it as high-security authentication or reuse a sensitive secret.
# VITE_PRIVATE_DEMO_ACCESS_CODE=replace-with-private-demo-code

# Stripe Payment Links
# Create these in Stripe Dashboard: https://dashboard.stripe.com/payment-links
# €99 Reality Check Report
VITE_STRIPE_LINK_BASIC=https://buy.stripe.com/YOUR_BASIC_LINK

# €149 Deep Dive Report  
VITE_STRIPE_LINK_PREMIUM=https://buy.stripe.com/YOUR_PREMIUM_LINK
