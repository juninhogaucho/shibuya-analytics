# Shibuya frontend environment example
# Copy to .env.local for local work, or set these in the deploy provider.

# API base URL
# Local development:
# VITE_API_BASE=http://localhost:8001
# Production:
# VITE_API_BASE=https://api.shibuya-analytics.com

# Private sample access gate
# Optional. If unset, controlled sample access is disabled.
# This is client-side presenter control only, not production authentication.
# Use at least 8 characters and do not leave a placeholder value.
# VITE_PRIVATE_DEMO_ACCESS_CODE=founder-only-example

# Launch proof
# Before treating a deployed frontend as live, run:
# npm run proof:frontend-env -- --target live --env-file .env.production
#
# Checkout uses backend Checkout Sessions through VITE_API_BASE.
# Do not configure legacy direct Stripe payment-link env vars for live launch.
